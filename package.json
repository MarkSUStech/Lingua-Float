{
  "name": "translate-float",
  "private": true,
  "version": "0.1.0",
  "description": "Minimal selection translation popup for Windows and Android.",
  "author": "Codex",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "run-p dev electron:start",
    "electron:start": "wait-on http://127.0.0.1:5173 && electron . --dev",
    "build": "tsc -b && vite build",
    "dict:build": "node scripts/build-dictionary.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "oxlint",
    "sync:android": "npm run build && cap sync android",
    "android:open": "cap open android",
    "dist:win": "npm run build && electron-builder --win portable"
  },
  "build": {
    "appId": "dev.codex.linguafloat",
    "productName": "Lingua Float",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/*.ico",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "npm-run-all": "^4.1.5",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "wait-on": "^9.0.10"
  }
}
